# 선택: OpenAI 키를 넣으면 TS 요약이 LLM 생성 요약으로 업그레이드됩니다
OPENAI_API_KEY=

# 선택: 한국은행 ECOS Open API 키 (https://ecos.bok.or.kr/api/#/발급 무료)
# 비워두면 공개 sample 키로 동작하되 최근 10개월만 조회됩니다
ECOS_API_KEY=

# 기준금리 백그라운드 자동 갱신 주기(초). 기본 1800(30분)
ECOS_REFRESH_SEC=1800

# 선택: 네이버 뉴스 검색 오픈API (https://developers.naver.com/apps/#/register 무료 발급)
# 두 값이 모두 있어야 실시간 뉴스 자동 수집이 켜집니다. 비워두면 수동 피드만 동작합니다.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 자동 수집할 검색어(쉼표 구분). 비워두면 기본값(기준금리,전세사기,대출 규제) 사용
NAVER_QUERIES=

# 네이버 뉴스 폴링 주기(초). 기본 300(5분)
NAVER_REFRESH_SEC=300
